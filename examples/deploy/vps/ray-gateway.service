[Unit]
Description=Ray Gateway
After=network.target

[Service]
Type=simple
User=ray
WorkingDirectory=/srv/ray
ExecStart=/usr/bin/node /srv/ray/apps/gateway/dist/index.js --config /etc/ray/ray.vps.json
Restart=always
RestartSec=2
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target

