{
  "profile": "1b",
  "server": {
    "host": "127.0.0.1",
    "port": 3000,
    "requestBodyLimitBytes": 48000
  },
  "model": {
    "id": "local-1b-q4",
    "family": "generic-1b",
    "quantization": "q4_k_m",
    "adapter": {
      "kind": "llama.cpp",
      "modelRef": "local-1b-q4",
      "launchProfile": {
        "modelPath": "/var/lib/ray/models/local-1b-q4.gguf",
        "alias": "local-1b-q4"
      }
    }
  },
  "scheduler": {
    "concurrency": 1,
    "maxQueue": 40,
    "maxQueuedTokens": 18000,
    "maxInflightTokens": 2048,
    "requestTimeoutMs": 32000,
    "dedupeInflight": true,
    "batchWindowMs": 5,
    "affinityLookahead": 12,
    "shortJobMaxTokens": 96
  },
  "asyncQueue": {
    "enabled": true,
    "storageDir": "/var/lib/ray/async-queue",
    "maxJobs": 1000,
    "minFreeStorageMiB": 256,
    "completedTtlMs": 86400000,
    "pollIntervalMs": 1000,
    "dispatchConcurrency": 1,
    "maxAttempts": 3,
    "callbackTimeoutMs": 5000,
    "maxCallbackAttempts": 5,
    "callbackAllowPrivateNetwork": false,
    "callbackAllowedHosts": []
  },
  "auth": {
    "enabled": true,
    "apiKeyEnv": "RAY_API_KEYS"
  },
  "rateLimit": {
    "enabled": true,
    "windowMs": 60000,
    "maxRequests": 75,
    "maxKeys": 4096,
    "keyStrategy": "ip+api-key",
    "trustProxyHeaders": true
  },
  "cache": {
    "enabled": true,
    "maxEntries": 256,
    "maxBytes": 2097152,
    "ttlMs": 120000,
    "keyStrategy": "input+params"
  },
  "telemetry": {
    "serviceName": "ray-gateway",
    "logLevel": "info",
    "includeDebugMetrics": true,
    "slowRequestThresholdMs": 2200
  },
  "gracefulDegradation": {
    "enabled": true,
    "queueDepthThreshold": 10,
    "maxPromptChars": 5000,
    "degradeToMaxTokens": 128,
    "memoryRssThresholdMiB": 512,
    "cpuThrottledRatioThreshold": 0.2
  },
  "promptCompiler": {
    "enabled": true,
    "collapseWhitespace": true,
    "dedupeRepeatedLines": true,
    "familyMetadataKeys": ["promptFamily", "taskTemplate", "template", "useCase"]
  },
  "adaptiveTuning": {
    "enabled": true,
    "sampleSize": 32,
    "queueLatencyThresholdMs": 600,
    "minCompletionTokensPerSecond": 8,
    "maxOutputReductionRatio": 0.5,
    "minOutputTokens": 64,
    "learnedFamilyCapEnabled": true,
    "familyHistorySize": 64,
    "learnedCapMinSamples": 8,
    "draftPercentile": 0.95,
    "shortPercentile": 0.9,
    "learnedCapHeadroomTokens": 24
  },
  "tags": {
    "target": "1b",
    "hardware": "generic-4gb-vps-class",
    "engine": "llama.cpp",
    "modelSize": "1b-class",
    "exposure": "public",
    "portability": "generic-model"
  }
}
