    "model:stage:hetzner-email-ai": "bun ./scripts/model-stage.ts --config ./examples/config/ray.hetzner-cx23-qwen0.6b.public.json",
    "test": "bun run build && bun ./scripts/test.mjs",
    "release:gate": "bun run lint && bun run format:check && bun run changeset:status && bun run test && bun run validate:config:all && RAY_API_KEYS=smoke bun run validate:config:public && bun run smoke:tiny && bun run smoke:tiny:public && bun run smoke:tiny:async && bun run smoke:tiny:public-async && bun run deploy:smoke && bun run model:stage:smoke && bun run deploy:scripts && bun run package:runtime && bun run docs:links && bun run pack:check",
    "release:check-source": "bun ./scripts/release/check-source.mjs",
    "release:verify-npm": "bun ./scripts/release/verify-npm.mjs",
    "release:github": "bash scripts/release/gh-release.sh",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "version": "changeset version && bun install",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:check": "bun ./scripts/release/pack-check.mjs",
    "typecheck": "tsc -b tsconfig.build.json --pretty false",
    "render:service": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.sub1b.public.json --systemd-env-file /etc/ray/ray.env",
    "render:service:cax11": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.sub1b.cax11.public.json --systemd-env-file /etc/ray/ray.env",
    "render:service:hetzner-email-ai": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.hetzner-cx23-qwen0.6b.public.json --systemd-env-file /etc/ray/ray.env --memory-mib 4096",
    "render:service:1b": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.1b.public.json --systemd-env-file /etc/ray/ray.env --memory-mib 4096",
    "render:service:1b:generic": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.1b.generic.public.json --systemd-env-file /etc/ray/ray.env --memory-mib 4096",
    "render:service:1b:8gb": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.1b.8gb.public.json --systemd-env-file /etc/ray/ray.env --memory-mib 8192",
    "render:service:1b:8gb:generic": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.1b.8gb.generic.public.json --systemd-env-file /etc/ray/ray.env --memory-mib 8192",
    "render:service:vps": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.vps.json --systemd-env-file /etc/ray/ray.env",
    "render:service:balanced": "bun ./packages/deploy/dist/cli.js render --cwd . --config ./examples/config/ray.balanced.json --systemd-env-file /etc/ray/ray.env",
