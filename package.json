{
  "name": "ray",
  "private": true,
  "version": "0.1.0",
  "description": "Shrink AI to run on cheap VPS infrastructure.",
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "bun ./scripts/clean.mjs",
    "dev": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.sub1b.json",
    "dev:sub1b": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.sub1b.json",
    "dev:sub1b:classifier": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.sub1b.classifier.json",
