    "dev:1b:generic": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.1b.generic.json",
    "dev:1b:generic:public": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.1b.generic.public.json",
    "dev:1b:public": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.1b.public.json",
    "dev:1b:8gb": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.1b.8gb.json",
    "dev:1b:8gb:generic": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.1b.8gb.generic.json",
    "dev:1b:8gb:generic:public": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.1b.8gb.generic.public.json",
    "dev:1b:8gb:public": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.1b.8gb.public.json",
    "dev:cax11": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.sub1b.cax11.json",
    "dev:tiny": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.tiny.json",
    "dev:vps": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.vps.json",
    "dev:balanced": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.balanced.json",
    "dev:hetzner-email-ai": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.hetzner-cx23-qwen0.6b.json",
    "dev:hetzner-email-ai:public": "bun --conditions=development ./apps/gateway/src/index.ts --config ./examples/config/ray.hetzner-cx23-qwen0.6b.public.json",
    "start": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.sub1b.json",
    "start:sub1b": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.sub1b.json",
    "start:sub1b:classifier": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.sub1b.classifier.json",
    "start:sub1b:drafter": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.sub1b.drafter.json",
    "start:1b": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.1b.json",
    "start:1b:generic": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.1b.generic.json",
