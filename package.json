    "start:1b:8gb": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.1b.8gb.json",
    "start:1b:8gb:generic": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.1b.8gb.generic.json",
    "start:1b:8gb:generic:public": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.1b.8gb.generic.public.json",
    "start:1b:8gb:public": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.1b.8gb.public.json",
    "start:cax11": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.sub1b.cax11.json",
    "start:tiny": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.tiny.json",
    "start:vps": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.vps.json",
    "start:balanced": "bun ./apps/gateway/dist/index.js --config ./examples/config/ray.balanced.json",
