{
  "name": "@ray/sdk",
  "version": "0.1.0",
  "description": "TypeScript client for the Ray inference gateway HTTP API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/ray.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "ray",
    "inference",
    "llm",
    "gateway",
    "client",
    "self-hosted"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "release:check-source": "node ./scripts/release/check-source.mjs"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@ray/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
