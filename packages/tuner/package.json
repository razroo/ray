{
  "name": "@razroo/ray-tuner",
  "version": "0.3.0",
  "description": "llama.cpp launch-profile tuner helpers for Ray VPS deployments",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/ray.git",
    "directory": "packages/tuner"
  },
  "keywords": [
    "ray",
    "razroo",
    "llama.cpp",
    "tuning",
    "vps",
    "inference",
    "self-hosted"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!dist/**/*.test.*",
    "!src/**/*.test.*",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@razroo/ray-core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
